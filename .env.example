# ── Database ──────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=bookkeeping

# ── Backend ──────────────────────────────────────
PORT=3001
JWT_SECRET=change-me-to-a-random-string
FRONTEND_URL=http://localhost:5173

# ── Frontend ─────────────────────────────────────
# For local dev, Vite proxies /api to the backend.
# For production (Docker/nginx), /api is proxied automatically.
# Set this only if the backend is on a different domain.
VITE_API_URL=/api

# ── Production (docker-compose.prod.yml) ────────
# DOMAIN=myapp.duckdns.org
